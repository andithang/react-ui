{
  "name": "@andithang/react-ui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "React component library with SCSS tokens, theme switching, and Storybook docs.",
  "main": "dist/react-ui.cjs",
  "module": "dist/react-ui.js",
  "types": "dist/index.d.ts",
  "style": "dist/react-ui.css",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-ui.js",
      "require": "./dist/react-ui.cjs"
    },
    "./styles.css": "./dist/react-ui.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-storybook:cname": "cross-env STORYBOOK_BASE_URL=/ storybook build",
    "build-storybook:gh": "cross-env STORYBOOK_BASE_URL=/react-ui/ storybook build",
    "prepare-storybook:static": "node scripts/prepare-storybook-static.mjs",
    "deploy:storybook": "npm run build-storybook:gh && npm run prepare-storybook:static && gh-pages -d storybook-static --dotfiles",
    "deploy:storybook:cname": "npm run build-storybook:cname && cross-env STORYBOOK_INCLUDE_CNAME=1 npm run prepare-storybook:static && gh-pages -d storybook-static --dotfiles -r https://x-access-token:${GITHUB_TOKEN}@github.com/${GITHUB_REPOSITORY}.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-docs": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/node": "^25.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "sass": "^1.89.2",
    "storybook": "^8.6.14",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "antd": "^6.3.2",
    "dayjs": "^1.11.20"
  }
}
